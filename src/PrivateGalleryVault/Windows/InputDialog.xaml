<Window x:Class="PrivateGalleryVault.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="입력"
        Width="560"
        Height="300"
        MinWidth="540"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#081322"
            BorderBrush="#2B3C55"
            BorderThickness="1"
            CornerRadius="18"
            Padding="0"
            Effect="{StaticResource SoftShadow}"
            TextElement.Foreground="{StaticResource Text}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#0A1628" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" MouseDown="DialogChrome_MouseDown">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" CornerRadius="10" Background="#11213A" BorderBrush="#2D4D7A" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="✎" Foreground="{StaticResource Accent2}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="TitleText" Grid.Column="1" Text="입력" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource Text}" />
                    <Button Grid.Column="2" Content="×" Style="{StaticResource GhostButton}" Width="34" Height="32" Padding="0" Click="Cancel_Click" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="28,24,28,10" TextElement.Foreground="{StaticResource Text}">
                <TextBlock x:Name="PromptText" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" TextWrapping="Wrap" Margin="0,0,0,14" />
                <TextBox x:Name="ValueBox" Height="46" VerticalContentAlignment="Center" FontSize="15" KeyDown="ValueBox_KeyDown" />
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0" Padding="22,18" Background="#081322" CornerRadius="0,0,18,18">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소" Style="{StaticResource GhostButton}" Click="Cancel_Click" Width="108" Margin="0,0,10,0" />
                    <Button Content="확인" Click="Ok_Click" Width="108" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
