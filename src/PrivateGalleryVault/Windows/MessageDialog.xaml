<Window x:Class="PrivateGalleryVault.Windows.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Private Gallery Vault"
        Width="620"
        SizeToContent="Height"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="#081322"
            BorderBrush="#2B3C55"
            BorderThickness="1"
            CornerRadius="18"
            Padding="0"
            Effect="{StaticResource SoftShadow}"
            TextElement.Foreground="{StaticResource Text}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#0A1628" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" MouseDown="DialogChrome_MouseDown">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="36" Height="36" CornerRadius="11" Background="#11213A" BorderBrush="#2D4D7A" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock x:Name="IconText" Text="ⓘ" Foreground="{StaticResource Accent2}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="TitleText" Grid.Column="1" Text="알림" Foreground="{StaticResource Text}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="×" Style="{StaticResource GhostButton}" Width="34" Height="32" Padding="0" Click="Close_Click" />
                </Grid>
            </Border>

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource Text}"
                       FontSize="15"
                       LineHeight="24"
                       Margin="28,24,28,24" />

            <Border Grid.Row="2" BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0" Padding="22,18" Background="#081322" CornerRadius="0,0,18,18">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Border>
</Window>
