<Window x:Class="PrivateGalleryVault.Windows.VideoThumbnailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="영상 썸네일 재설정" Width="920" Height="720" MinWidth="820" MinHeight="640"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#020617" Foreground="#F8FAFC">
    <Grid Background="#06101D">
        <Border Margin="18"
                Background="#071221"
                BorderBrush="#24364E"
                BorderThickness="1"
                CornerRadius="24"
                Padding="22">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock x:Name="HeaderText" Text="영상 썸네일 재설정" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" />
                        <TextBlock Text="영상 원본에서 원하는 프레임을 선택한 뒤 1:1 크롭으로 저장합니다. 기존에 찌그러진 썸네일을 다시 편집하지 않습니다."
                                   Foreground="{StaticResource SubText}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#06111F" BorderBrush="#223652" BorderThickness="1" CornerRadius="22" Padding="12" ClipToBounds="True">
                    <Grid Background="#000000" ClipToBounds="True">
                        <MediaElement x:Name="PreviewPlayer"
                                      LoadedBehavior="Manual"
                                      UnloadedBehavior="Manual"
                                      Stretch="Uniform"
                                      ScrubbingEnabled="True"
                                      MediaOpened="PreviewPlayer_MediaOpened"
                                      MediaFailed="PreviewPlayer_MediaFailed" />
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#CC0B1220" CornerRadius="10" Padding="10,5" Margin="12">
                            <TextBlock x:Name="CurrentTimeText" Text="00:00 / 00:00" Foreground="#BFDBFE" FontWeight="SemiBold" FontSize="12" />
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,16,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Slider x:Name="TimelineSlider"
                                Grid.Row="0"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                PreviewMouseLeftButtonDown="TimelineSlider_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="TimelineSlider_PreviewMouseLeftButtonUp"
                                ValueChanged="TimelineSlider_ValueChanged" />
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PlayPauseButton" Grid.Column="0" Content="재생" Style="{StaticResource GhostButton}" Width="86" Height="38" Click="PlayPause_Click" Margin="0,0,8,0" />
                            <Button Grid.Column="1" Content="-0.5초" Style="{StaticResource GhostButton}" Width="86" Height="38" Click="BackHalf_Click" Margin="0,0,8,0" />
                            <Button Grid.Column="2" Content="+0.5초" Style="{StaticResource GhostButton}" Width="86" Height="38" Click="ForwardHalf_Click" />
                            <TextBlock Grid.Column="3" Text="팁: 얼굴이나 주요 피사체가 중앙에 오는 시점에서 크롭을 시작하세요." Foreground="{StaticResource MutedText}" VerticalAlignment="Center" Margin="14,0" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="4" Content="현재 프레임 크롭/저장" Width="170" Height="38" Click="CaptureAndCrop_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="16">
                    <Grid>
                        <TextBlock Text="저장 시 원본 비율 프레임 소스와 최종 정사각 썸네일을 함께 암호화해 보관합니다." Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="취소" Style="{StaticResource GhostButton}" Width="92" Height="40" Click="Cancel_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
