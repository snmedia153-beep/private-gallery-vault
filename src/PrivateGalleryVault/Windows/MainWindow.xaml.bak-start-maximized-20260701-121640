                                                    <TextBlock Grid.Column="1" Text="⠿" Foreground="#BFDBFE" FontSize="18" ToolTip="핸들을 잡아 주제 순서 변경" Cursor="SizeAll" PreviewMouseLeftButtonDown="ReorderHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="ReorderHandle_PreviewMouseMove" />
                                                </Grid>
                                                <TextBlock Text="{Binding CountText}" Foreground="{StaticResource SubText}" Margin="14,4,14,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox x:Name="TopicLinearList" Visibility="Collapsed" SelectionChanged="TopicCard_SelectionChanged" PreviewMouseLeftButtonDown="ReorderList_PreviewMouseLeftButtonDown" PreviewMouseMove="ReorderTopicCardList_PreviewMouseMove" DragOver="ReorderTopicCardList_DragOver" DragLeave="ReorderList_DragLeave" Drop="ReorderTopicCardList_Drop" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" AllowDrop="True">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,6" Padding="12" Background="#111D2F" CornerRadius="14" BorderBrush="#26364D" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="96" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="⠿" Foreground="#94A3B8" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="핸들을 잡아 순서 변경" Cursor="SizeAll" PreviewMouseLeftButtonDown="ReorderHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="ReorderHandle_PreviewMouseMove" />
                                                <Border Grid.Column="1" Width="82" Height="62" Background="#050B14" CornerRadius="10" ClipToBounds="True"><Image Source="{Binding CoverImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" /></Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource SubText}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding CountText}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Border x:Name="TopicAutoScrollTopHint" Visibility="Collapsed" Height="44" VerticalAlignment="Top" IsHitTestVisible="False" CornerRadius="12" Opacity="0.95">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#773B82F6" Offset="0" />
                                        <GradientStop Color="#003B82F6" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="▲ 위로 자동 스크롤" Foreground="#BFDBFE" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" />
                            </Border>
                            <Border x:Name="TopicAutoScrollBottomHint" Visibility="Collapsed" Height="44" VerticalAlignment="Bottom" IsHitTestVisible="False" CornerRadius="12" Opacity="0.95">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#773B82F6" Offset="0" />
                                        <GradientStop Color="#003B82F6" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="▼ 아래로 자동 스크롤" Foreground="#BFDBFE" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="2" Background="#0A1322" BorderBrush="{StaticResource Stroke}" BorderThickness="1,0,0,0">
                <ScrollViewer x:Name="TopicDetailScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              Padding="0,0,8,0">
                    <StackPanel Margin="22">
                        <TextBlock Text="선택된 주제 정보" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text}" />
                        <TextBlock Text="주제와 미디어 보관 상태" Foreground="{StaticResource SubText}" Margin="0,4,0,18" />
                        <Border Style="{StaticResource Card}" Padding="16" Background="#0D1726">
                            <StackPanel>
                                <Border Height="142" Background="#050B14" BorderBrush="#18283D" BorderThickness="1" CornerRadius="14" ClipToBounds="True" Margin="0,0,0,14"><Image x:Name="TopicCoverImage" Source="/Assets/Images/topic_default_folder.png" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" /></Border>
                                <TextBlock x:Name="SelectedTopicTitleText" Text="전체" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}" TextWrapping="Wrap" />
                                <TextBlock x:Name="MediaCountText" Text="0개 항목" Foreground="{StaticResource SubText}" Margin="0,5,0,14" />
                                <TextBlock Text="설명" Foreground="{StaticResource SubText}" />
                                <TextBlock x:Name="TopicDescriptionText" Text="주제를 선택하세요." Foreground="{StaticResource Text}" TextWrapping="Wrap" Margin="0,5,0,0" />
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,16,0,0">
                            <Button Content="썸네일 지정" Click="SetTopicCover_Click" Margin="0,0,0,8" />
                            <Button Content="이름 변경" Style="{StaticResource GhostButton}" Click="RenameTopic_Click" Margin="0,0,0,8" />
                            <Button Content="설명 수정" Style="{StaticResource GhostButton}" Click="EditTopicDescription_Click" Margin="0,0,0,8" />
                            <Button Content="삭제" Style="{StaticResource DangerButton}" Click="DeleteTopic_Click" />
                        </StackPanel>

                        <Border Style="{StaticResource Card}" Padding="14" Background="#0D1726" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="주제 미디어 필터" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Text}" />
                                <TextBlock Text="선택한 주제 안에서 자주 쓰는 항목만 빠르게 봅니다." Foreground="{StaticResource SubText}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,12" />
                                <Button x:Name="TopicDetailVideosButton" Style="{StaticResource SidebarButton}" Click="Videos_Click" Height="36" Margin="0,0,0,7">
                                    <Grid>
                                        <TextBlock Text="동영상" />
                                        <Border HorizontalAlignment="Right" Style="{StaticResource CountBadge}"><TextBlock x:Name="TopicDetailVideosCountText" Text="0" /></Border>
                                    </Grid>
                                </Button>
                                <Button x:Name="TopicDetailImagesButton" Style="{StaticResource SidebarButton}" Click="Images_Click" Height="36" Margin="0,0,0,7">
                                    <Grid>
                                        <TextBlock Text="이미지" />
                                        <Border HorizontalAlignment="Right" Style="{StaticResource CountBadge}"><TextBlock x:Name="TopicDetailImagesCountText" Text="0" /></Border>
                                    </Grid>
                                </Button>
                                <Button x:Name="TopicDetailFavoritesButton" Style="{StaticResource SidebarButton}" Click="Favorites_Click" Height="36">
                                    <Grid>
                                        <TextBlock Text="즐겨찾기" />
                                        <Border HorizontalAlignment="Right" Style="{StaticResource CountBadge}"><TextBlock x:Name="TopicDetailFavoritesCountText" Text="0" /></Border>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="사용 팁" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="0,24,0,8" />
                        <TextBlock Foreground="{StaticResource SubText}" TextWrapping="Wrap" LineHeight="22"
                                   Text="• 파일은 AES-256 암호화로 안전하게 보호됩니다.&#x0a;• 마우스 휠로 이미지 확대/축소, 클릭 드래그로 이동합니다.&#x0a;• 주제 썸네일은 기존 미디어에서 직접 지정할 수 있습니다.&#x0a;• 자동 잠금 타이머는 설정에서 변경할 수 있습니다." />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="ManagementOverlay" Grid.Column="1" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#07111F" BorderBrush="{StaticResource Stroke}" BorderThickness="1,0,0,0">
                <Grid Margin="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="ManagementTitleText" Text="관리 센터" FontSize="28" FontWeight="Bold" />
                            <TextBlock x:Name="ManagementSubtitleText" Text="최근 기록, 중복 관리, 백업/복원, 태그/라벨을 한 화면에서 관리합니다." Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="← 갤러리로 돌아가기" Style="{StaticResource GhostButton}" Click="CloseManagement_Click" />
                    </Grid>
                    <ContentControl x:Name="ManagementContentHost" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#020617" BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="준비됨" Foreground="{StaticResource SubText}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis" />
                <Border x:Name="ImportProgressPanel" Grid.Column="1" Visibility="Collapsed" Background="#0B1220" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10" Padding="10,5" Margin="12,0,14,0" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ImportProgressText" Text="가져오기 0 / 0" Foreground="{StaticResource Text}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ProgressBar x:Name="ImportProgressBar" Grid.Column="1" Height="8" Minimum="0" Maximum="1" Value="0" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <TextBlock Grid.Column="2" x:Name="AutoLockStatusText" Text="자동 잠금: 1시간" Foreground="{StaticResource SubText}" VerticalAlignment="Center" FontSize="12" />
            </Grid>
        </Border>


        <Border x:Name="ContentBusyOverlay" Grid.Row="1" Visibility="Collapsed" Background="#99020712" IsHitTestVisible="True">
            <Grid>
                <Border Width="420" MinHeight="230" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#0B1220" BorderBrush="#3B82F6" BorderThickness="1.4" CornerRadius="24" Padding="26">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="34" ShadowDepth="0" Opacity="0.62" />
                    </Border.Effect>
                    <StackPanel>
                        <Grid Width="72" Height="72" HorizontalAlignment="Center" Margin="0,2,0,18">
                            <Ellipse Stroke="#1E3A8A" StrokeThickness="6" Opacity="0.9" />
                            <Ellipse Stroke="#60A5FA" StrokeThickness="6" StrokeDashArray="2 4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="ContentBusySpinnerRotate" Angle="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="ContentBusySpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.05" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="🔐" FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock x:Name="ContentBusyTitleText" Text="목록 불러오는 중" Foreground="White" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ContentBusyDetailText" Text="썸네일을 안전하게 불러오고 있습니다." Foreground="#BFDBFE" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" LineHeight="20" Margin="0,8,0,20" />
                        <ProgressBar x:Name="ContentBusyPulseBar" Height="6" IsIndeterminate="True" Margin="0,0,0,10" />
                        <ProgressBar x:Name="ContentBusyProgressBar" Height="10" Minimum="0" Maximum="1" Value="0" />
                        <Grid Margin="0,12,0,0">
                            <TextBlock x:Name="ContentBusyProgressText" Text="준비 중" Foreground="#E5E7EB" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" />
                            <TextBlock Text="잠시만 기다려주세요" Foreground="#64748B" FontSize="11" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ImportModalOverlay" Grid.RowSpan="3" Visibility="Collapsed" Background="#AA020617" IsHitTestVisible="True">
            <Grid>
                <Border Width="440" MinHeight="250" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#0B1220" BorderBrush="#3B82F6" BorderThickness="1.4" CornerRadius="24" Padding="26">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="34" ShadowDepth="0" Opacity="0.62" />
                    </Border.Effect>
                    <StackPanel>
                        <Grid Width="76" Height="76" HorizontalAlignment="Center" Margin="0,2,0,18">
                            <Ellipse Stroke="#1E3A8A" StrokeThickness="6" Opacity="0.9" />
                            <Ellipse Stroke="#60A5FA" StrokeThickness="6" StrokeDashArray="2 4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="ImportModalSpinnerRotate" Angle="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="ImportModalSpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="🔒" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock x:Name="ImportModalTitleText" Text="파일 가져오는 중" Foreground="White" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ImportModalDetailText" Text="암호화 저장을 준비하고 있습니다." Foreground="#BFDBFE" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" LineHeight="20" Margin="0,8,0,20" />

                        <ProgressBar x:Name="ImportModalPulseBar" Height="6" IsIndeterminate="True" Margin="0,0,0,10" />
                        <ProgressBar x:Name="ImportModalProgressBar" Height="10" Minimum="0" Maximum="1" Value="0" />

                        <Grid Margin="0,12,0,0">
                            <TextBlock x:Name="ImportModalProgressText" Text="파일 목록 확인 중" Foreground="#E5E7EB" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" />
                            <TextBlock Text="완료되면 자동으로 닫힙니다" Foreground="#64748B" FontSize="11" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
