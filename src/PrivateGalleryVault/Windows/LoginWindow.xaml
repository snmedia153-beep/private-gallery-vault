<Window x:Class="PrivateGalleryVault.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vault 잠금 해제"
        Width="1040"
        Height="640"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Background="{StaticResource AppBackground}" TextElement.Foreground="{StaticResource Text}">
        <Grid.RowDefinitions>
            <RowDefinition Height="76" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#081322" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" CornerRadius="14" Background="#0F1E33" BorderBrush="#2D4D7A" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,14,0">
                    <Image Source="/Assets/Images/logo_shield.png" Width="36" Height="36" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Private Gallery Vault" Foreground="{StaticResource Text}" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="안전하게 암호화된 개인 이미지 · 영상 갤러리" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,3,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                Margin="70,38"
                Padding="0"
                Effect="{StaticResource SoftShadow}"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0A1423" CornerRadius="18,0,0,18" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,1,0" ClipToBounds="True">
                    <Grid Margin="34,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Image Source="/Assets/Images/illustration_unlock.png" Stretch="Uniform" Height="150" HorizontalAlignment="Center" Margin="0,0,0,14" />
                        <TextBlock Grid.Row="1"
                                   Text="안전한 로컬 암호화 Vault"
                                   Foreground="{StaticResource Text}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   TextAlignment="Center"
                                   Margin="0,0,0,16" />
                        <StackPanel Grid.Row="2" VerticalAlignment="Top">
                            <Border Background="#0D1A2D" BorderBrush="#203552" BorderThickness="1" CornerRadius="12" Padding="14,12" Margin="0,0,0,8">
                                <TextBlock Text="🔒  모든 데이터는 로컬에만 저장됩니다." Foreground="{StaticResource SubText}" FontSize="13" TextWrapping="Wrap" />
                            </Border>
                            <Border Background="#0D1A2D" BorderBrush="#203552" BorderThickness="1" CornerRadius="12" Padding="14,12" Margin="0,0,0,8">
                                <TextBlock Text="🛡  AES-256 암호화로 보호됩니다." Foreground="{StaticResource SubText}" FontSize="13" TextWrapping="Wrap" />
                            </Border>
                            <Border Background="#0D1A2D" BorderBrush="#203552" BorderThickness="1" CornerRadius="12" Padding="14,12">
                                <TextBlock Text="👁  비밀번호 없이는 파일에 접근할 수 없습니다." Foreground="{StaticResource SubText}" FontSize="13" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="44,34,44,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="31" FontWeight="Bold" Foreground="{StaticResource Text}" Margin="0,0,0,4">
                        <Run Text="Vault " />
                        <Run Text="잠금 해제" Foreground="{StaticResource Accent2}" />
                    </TextBlock>
                    <TextBlock Grid.Row="1" Text="마스터 비밀번호를 입력하여 암호화된 이미지와 영상을 확인하세요."
                               Foreground="{StaticResource SubText}" FontSize="14" TextWrapping="Wrap" Margin="0,4,0,24" />

                    <TextBlock Grid.Row="2" Text="마스터 비밀번호" Foreground="{StaticResource Text}" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Grid Grid.Row="3">
                        <PasswordBox x:Name="PasswordBox" Height="46" KeyDown="PasswordBox_KeyDown" FontSize="15" VerticalContentAlignment="Center" />
                        <TextBox x:Name="PasswordTextBox" Height="46" Visibility="Collapsed" KeyDown="PasswordTextBox_KeyDown" FontSize="15" VerticalContentAlignment="Center" />
                    </Grid>

                    <CheckBox Grid.Row="4" x:Name="ShowPasswordCheck" Content="비밀번호 표시" Foreground="{StaticResource Text}" Margin="0,14,0,0" Checked="ShowPasswordCheck_Changed" Unchecked="ShowPasswordCheck_Changed" />

                    <TextBlock Grid.Row="5" x:Name="MessageText" Foreground="{StaticResource Danger}" TextWrapping="Wrap" Margin="0,10,0,0" MinHeight="20" FontWeight="SemiBold" />

                    <Button Grid.Row="6" Content="🔓  잠금 해제" Click="Unlock_Click" Height="50" Margin="0,8,0,18" FontSize="15" />

                    <Grid Grid.Row="7">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Height="1" Background="{StaticResource Stroke}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="또는" Foreground="{StaticResource SubText}" FontWeight="SemiBold" Margin="16,0" />
                            <Border Grid.Column="2" Height="1" Background="{StaticResource Stroke}" VerticalAlignment="Center" />
                        </Grid>
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="🔑  비밀번호 변경" Style="{StaticResource GhostButton}" Click="ChangePassword_Click" Height="44" Margin="0,0,10,0" Foreground="{StaticResource Text}" />
                            <Button Grid.Column="1" Content="종료" Style="{StaticResource GhostButton}" Click="Cancel_Click" Height="44" Margin="10,0,0,0" Foreground="{StaticResource Text}" />
                        </Grid>
                        <Border Grid.Row="2" Background="#0B1627" BorderBrush="#253952" BorderThickness="1" CornerRadius="13" Padding="14" Margin="0,18,0,0" VerticalAlignment="Top">
                            <TextBlock Text="ⓘ  이 Vault는 오직 이 기기에서만 접근 가능합니다. 자동 잠금 후에는 다시 비밀번호가 필요합니다."
                                       Foreground="{StaticResource SubText}" TextWrapping="Wrap" LineHeight="21" />
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
