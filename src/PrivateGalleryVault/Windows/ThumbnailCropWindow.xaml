<Window x:Class="PrivateGalleryVault.Windows.ThumbnailCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="썸네일 크롭" Width="760" Height="720" MinWidth="700" MinHeight="660"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" Background="#020617" Foreground="#F8FAFC">
    <Grid Background="#06101D">
        <Border Margin="18"
                Background="#071221"
                BorderBrush="#24364E"
                BorderThickness="1"
                CornerRadius="24"
                Padding="22">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.28" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock x:Name="HeaderText" Text="썸네일 크롭" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" />
                        <TextBlock Text="드래그로 위치를 맞추고, 휠 또는 슬라이더로 확대/축소한 뒤 저장하세요. 결과는 1:1 정사각 썸네일로 저장됩니다."
                                   Foreground="{StaticResource SubText}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#06111F" BorderBrush="#223652" BorderThickness="1" CornerRadius="22" Padding="18">
                    <Grid>
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#050B14" BorderBrush="#2F7CFF" BorderThickness="2" CornerRadius="18" Padding="10">
                            <Grid>
                                <Border x:Name="CropFrame" Width="480" Height="480" Background="#000000" ClipToBounds="True" CornerRadius="12"
                                        Cursor="Hand"
                                        PreviewMouseWheel="CropFrame_PreviewMouseWheel"
                                        PreviewMouseLeftButtonDown="CropFrame_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="CropFrame_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="CropFrame_PreviewMouseLeftButtonUp"
                                        MouseLeave="CropFrame_MouseLeave">
                                    <Canvas x:Name="CropCanvas" Width="480" Height="480" ClipToBounds="True">
                                        <Image x:Name="PreviewImage" Stretch="Fill" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" />
                                    </Canvas>
                                </Border>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#CC0B1220" CornerRadius="10" Padding="10,5" Margin="0,12,12,0">
                                    <TextBlock Text="480 × 480" Foreground="#BFDBFE" FontWeight="SemiBold" FontSize="12" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,16,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="확대" Foreground="{StaticResource SubText}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0" />
                        <Slider x:Name="ZoomSlider" Grid.Column="1" Minimum="1" Maximum="5" Value="1" TickFrequency="0.1" IsSnapToTickEnabled="False" ValueChanged="ZoomSlider_ValueChanged" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="리셋" Style="{StaticResource GhostButton}" Width="76" Height="38" Margin="14,0,0,0" Click="Reset_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="16">
                    <Grid>
                        <TextBlock Text="팁: 원본 이미지는 변경하지 않고 암호화된 썸네일 파일만 교체됩니다." Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="취소" Style="{StaticResource GhostButton}" Width="92" Height="40" Margin="0,0,8,0" Click="Cancel_Click" />
                            <Button Content="썸네일 저장" Width="132" Height="40" Click="Save_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
