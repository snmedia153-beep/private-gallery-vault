<Window x:Class="PrivateGalleryVault.Windows.TopicChooserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="주제 선택"
        Width="560"
        Height="580"
        MinWidth="520"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#081322"
            BorderBrush="#2B3C55"
            BorderThickness="1"
            CornerRadius="18"
            Padding="0"
            Effect="{StaticResource SoftShadow}"
            TextElement.Foreground="{StaticResource Text}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="#0A1628" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" MouseDown="DialogChrome_MouseDown">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Source="/Assets/Images/topic_default_folder.png" Width="36" Height="36" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="주제 선택" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text}" />
                        <TextBlock x:Name="SubtitleText" Text="선택한 미디어를 이동할 주제를 고르세요." Foreground="{StaticResource SubText}" FontSize="12" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="×" Style="{StaticResource GhostButton}" Width="34" Height="32" Padding="0" Click="Cancel_Click" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="1" Text="이동할 주제를 선택하세요." FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Text}" Margin="24,20,24,10" />

            <Border Grid.Row="2" Background="#0A1322" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="24,0,24,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⌕" Foreground="{StaticResource Accent2}" FontSize="17" VerticalAlignment="Center" Margin="3,0,10,0" />
                    <Grid Grid.Column="1">
                        <TextBlock x:Name="SearchPlaceholderText"
                                   Text="주제 이름 또는 설명 검색"
                                   Foreground="{StaticResource MutedText}"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"
                                   IsHitTestVisible="False" />
                        <TextBox x:Name="TopicSearchBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource Text}"
                                 FontSize="14"
                                 Height="34"
                                 Padding="2,7,2,0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TopicSearchBox_TextChanged"
                                 ToolTip="주제 이름 또는 설명으로 필터링" />
                    </Grid>
                    <TextBlock x:Name="SearchCountText" Grid.Column="2" Text="" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" Margin="10,0,8,0" />
                    <Button x:Name="ClearSearchButton" Grid.Column="3" Content="×" Width="28" Height="28" Style="{StaticResource GhostButton}" Padding="0" Click="ClearSearch_Click" Visibility="Collapsed" ToolTip="검색어 지우기" />
                </Grid>
            </Border>

            <Border Grid.Row="3" Background="#0A1322" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="24,0,24,0">
                <Grid>
                    <ListBox x:Name="TopicList" MouseDoubleClick="TopicList_MouseDoubleClick" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="TopicItemBorder" Margin="0,4" Padding="12" Background="#111D2F" BorderBrush="#26364D" BorderThickness="1" CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="▣" Foreground="{StaticResource Accent2}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedText}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="#132034" CornerRadius="10" Padding="9,4" VerticalAlignment="Center" Margin="14,0,0,0">
                                            <TextBlock Text="{Binding ItemCount, StringFormat={}{0}개}" Foreground="{StaticResource SubText}" FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="TopicItemBorder" Property="Background" Value="#132846" />
                                        <Setter TargetName="TopicItemBorder" Property="BorderBrush" Value="{StaticResource Accent}" />
                                    </DataTrigger>
                                    <Trigger SourceName="TopicItemBorder" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TopicItemBorder" Property="Background" Value="#12243A" />
                                        <Setter TargetName="TopicItemBorder" Property="BorderBrush" Value="#2C4B70" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel x:Name="EmptySearchPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="검색 결과가 없습니다." Foreground="{StaticResource Text}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="다른 키워드로 검색하거나 검색어를 지워보세요." Foreground="{StaticResource SubText}" FontSize="12" Margin="0,6,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" BorderBrush="{StaticResource Stroke}" BorderThickness="0,1,0,0" Padding="22,18" Background="#081322" CornerRadius="0,0,18,18" Margin="0,18,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소" Style="{StaticResource GhostButton}" Click="Cancel_Click" Width="108" Margin="0,0,10,0" />
                    <Button Content="이동" Click="Ok_Click" Width="108" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
