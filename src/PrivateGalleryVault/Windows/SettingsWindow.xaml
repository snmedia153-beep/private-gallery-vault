<Window x:Class="PrivateGalleryVault.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="보안 및 설정"
        Width="1160" Height="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Grid Background="Transparent" TextElement.Foreground="{StaticResource Text}">
        <!-- Shadow breathing room: keeps the settings window visually separated from MainWindow. -->
        <Border Margin="22"
                Background="{StaticResource AppBackground}"
                BorderBrush="#3B82F6"
                BorderThickness="1.4"
                CornerRadius="24"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="34" ShadowDepth="12" Opacity="0.55" />
            </Border.Effect>

            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Custom dark title/header area -->
                <Border Grid.Row="0"
                        Background="#0A1423"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="24,24,0,0"
                        Padding="26,18,20,17"
                        MouseLeftButtonDown="DragWindow_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="64" Height="64"
                                Background="#081323"
                                BorderBrush="#1F3B63"
                                BorderThickness="1"
                                CornerRadius="18"
                                Margin="0,0,18,0">
                            <Image Source="/Assets/Images/illustration_security.png"
                                   Width="52" Height="52"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="보안 및 설정"
                                       FontSize="27"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource Text}" />
                            <TextBlock Text="Vault 보안, 비밀번호, 자동 잠금 정책을 관리합니다."
                                       Foreground="{StaticResource SubText}"
                                       Margin="0,5,0,0" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Content="✕"
                                Style="{StaticResource GhostButton}"
                                Width="42" Height="38"
                                Padding="0"
                                FontSize="15"
                                ToolTip="닫기"
                                Click="Cancel_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#07111F"
                        Padding="26,22,26,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,10,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.22*" MinWidth="590" />
                                <ColumnDefinition Width="0.92*" MinWidth="395" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="1  비밀번호 변경"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Text}" />
                                        <TextBlock Text="현재 비밀번호를 확인하고 새 비밀번호로 교체합니다."
                                                   Foreground="{StaticResource SubText}"
                                                   Margin="0,6,0,16"
                                                   TextWrapping="Wrap" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,9,0">
                                                <TextBlock Text="현재 비밀번호" Foreground="{StaticResource Text}" Margin="0,0,0,7" />
                                                <PasswordBox x:Name="CurrentPasswordBox" Height="42" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="9,0,0,0">
                                                <TextBlock Text="새 비밀번호" Foreground="{StaticResource Text}" Margin="0,0,0,7" />
                                                <PasswordBox x:Name="NewPasswordBox" Height="42" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,15,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="새 비밀번호 확인" Foreground="{StaticResource Text}" Margin="0,0,0,7" />
                                                <PasswordBox x:Name="ConfirmPasswordBox" Height="42" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="비밀번호 변경 저장"
                                                    Click="ChangePassword_Click"
                                                    VerticalAlignment="Bottom"
                                                    Margin="14,0,0,0"
                                                    MinWidth="160"
                                                    Height="42" />
                                        </Grid>
                                        <TextBlock x:Name="PasswordMessageText"
                                                   Foreground="{StaticResource Danger}"
                                                   Margin="0,12,0,0"
                                                   TextWrapping="Wrap"
                                                   MinHeight="22" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="2  자동 잠금 타이머"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Text}" />
                                        <TextBlock Text="마우스/키보드 입력이 없는 상태로 설정 시간이 지나면 자동으로 Vault를 잠급니다."
                                                   Foreground="{StaticResource SubText}"
                                                   Margin="0,6,0,16"
                                                   TextWrapping="Wrap" />
                                        <UniformGrid Columns="5" Rows="1">
                                            <RadioButton x:Name="Lock30" Content="30분" Tag="30" GroupName="AutoLock" Margin="0,0,8,0" />
                                            <RadioButton x:Name="Lock60" Content="1시간" Tag="60" GroupName="AutoLock" Margin="0,0,8,0" />
                                            <RadioButton x:Name="Lock180" Content="3시간" Tag="180" GroupName="AutoLock" Margin="0,0,8,0" />
                                            <RadioButton x:Name="Lock360" Content="6시간" Tag="360" GroupName="AutoLock" Margin="0,0,8,0" />
                                            <RadioButton x:Name="Lock480" Content="8시간" Tag="480" GroupName="AutoLock" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="3  페이지 표시 개수"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Text}" />
                                        <TextBlock Text="한 주제 안에 파일이 많을 때 한 페이지에 표시할 항목 수를 정합니다."
                                                   Foreground="{StaticResource SubText}"
                                                   Margin="0,6,0,16"
                                                   TextWrapping="Wrap" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="210" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="많은 파일을 보관할수록 48~96개를 권장합니다."
                                                       Foreground="{StaticResource MutedText}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap" />
                                            <ComboBox x:Name="ItemsPerPageCombo"
                                                      Grid.Column="1"
                                                      Height="42"
                                                      VerticalContentAlignment="Center">
                                                <ComboBoxItem Content="24개" Tag="24" />
                                                <ComboBoxItem Content="48개" Tag="48" />
                                                <ComboBoxItem Content="72개" Tag="72" />
                                                <ComboBoxItem Content="96개" Tag="96" />
                                                <ComboBoxItem Content="144개" Tag="144" />
                                                <ComboBoxItem Content="200개" Tag="200" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="4  보안 및 앱 설정"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Text}"
                                                   Margin="0,0,0,12" />
                                        <CheckBox x:Name="LockOnStartupCheck" Content="앱 시작 시 Vault 잠금 상태로 시작" Foreground="{StaticResource Text}" Margin="0,8" />
                                        <CheckBox x:Name="LockOnMinimizeCheck" Content="앱 최소화 시 자동 잠금" Foreground="{StaticResource Text}" Margin="0,8" />
                                        <CheckBox x:Name="CleanTempOnExitCheck" Content="종료 시 임시 파일과 캐시 정리" Foreground="{StaticResource Text}" Margin="0,8" />
                                        <CheckBox x:Name="DeleteTempAfterPlaybackCheck" Content="동영상 재생 후 임시 파일 즉시 삭제" Foreground="{StaticResource Text}" Margin="0,8" />
                                        <CheckBox x:Name="PlayVideosMutedCheck" Content="영상 열 때 음소거 상태로 재생" Foreground="{StaticResource Text}" Margin="0,8" />

                                        <Border Background="#081323" BorderBrush="#1F3B63" BorderThickness="1" CornerRadius="14" Padding="14" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="즉시 잠금 단축키" Foreground="{StaticResource Text}" FontWeight="SemiBold" />
                                                <TextBlock Text="등록한 조합키를 누르면 열려 있는 뷰어/모달을 닫고 즉시 잠금 화면으로 전환합니다."
                                                           Foreground="{StaticResource SubText}" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,12" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="InstantLockKeyBox"
                                                             Height="42"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             Padding="12,8,12,0"
                                                             VerticalContentAlignment="Center"
                                                             PreviewKeyDown="InstantLockKeyBox_PreviewKeyDown"
                                                             ToolTip="클릭 후 Ctrl/Alt/Shift와 함께 원하는 키를 누르세요. 예: Ctrl+X" />
                                                    <Button Grid.Column="1" Content="키 지우기" Style="{StaticResource GhostButton}" Width="96" Height="42" Margin="10,0,0,0" Click="ClearInstantLockKey_Click" />
                                                </Grid>
                                                <TextBlock Text="예: Ctrl+X를 등록하면 이 프로그램에 포커스가 있을 때 Ctrl+X로 즉시 잠금됩니다. 단일 문자 키는 입력 중 오작동 방지를 위해 사용하지 않습니다."
                                                           Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="5  저장 공간 및 Vault 정보"
                                                   FontSize="19"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Text}"
                                                   TextWrapping="Wrap" />
                                        <Border Background="#081323"
                                                BorderBrush="#1F3B63"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="10"
                                                Margin="0,16,0,18">
                                            <Image Source="/Assets/Images/empty_media.png"
                                                   Height="132"
                                                   Stretch="Uniform" />
                                        </Border>

                                        <Border Background="#0A1423"
                                                BorderBrush="{StaticResource Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="16">
                                            <StackPanel>
                                                <TextBlock Text="Vault 위치" Foreground="{StaticResource SubText}" Margin="0,0,0,6" />
                                                <TextBlock x:Name="VaultPathText"
                                                           Foreground="{StaticResource Text}"
                                                           TextWrapping="Wrap"
                                                           FontSize="12.5"
                                                           LineHeight="18" />

                                                <Grid Margin="0,18,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="암호화 알고리즘" Foreground="{StaticResource SubText}" />
                                                    <TextBlock Grid.Column="1" Text="AES-256-GCM" Foreground="{StaticResource Text}" TextAlignment="Right" />
                                                </Grid>
                                                <Grid Margin="0,14,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="키 파생 함수" Foreground="{StaticResource SubText}" />
                                                    <TextBlock Grid.Column="1" Text="PBKDF2-SHA256" Foreground="{StaticResource Text}" TextAlignment="Right" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Background="#101B2C"
                                                BorderBrush="{StaticResource Stroke}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="16"
                                                Margin="0,18,0,0">
                                            <TextBlock Text="🛡  비밀번호는 서버에 저장되지 않습니다. 분실 시 복구할 수 없으므로 반드시 안전한 곳에 기록하세요."
                                                       Foreground="{StaticResource SubText}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="22" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="#081323"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,24,24"
                        Padding="26,18,26,20">
                    <Grid>
                        <TextBlock Text="변경 내용을 저장하면 자동 잠금 정책이 즉시 반영됩니다."
                                   Foreground="{StaticResource MutedText}"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="취소"
                                    Style="{StaticResource GhostButton}"
                                    Click="Cancel_Click"
                                    Margin="0,0,10,0"
                                    Width="120" />
                            <Button Content="저장"
                                    Click="Save_Click"
                                    Width="144" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
