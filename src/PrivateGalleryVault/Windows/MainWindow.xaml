<Window x:Class="PrivateGalleryVault.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Private Gallery Vault" Width="1520" Height="930" MinWidth="960" MinHeight="640" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
    <Window.Resources>
        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="Background" Value="#17283F" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="MinWidth" Value="26" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource SubText}" />
            <Setter Property="TextElement.FontSize" Value="11" />
            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
        </Style>

        <ItemsPanelTemplate x:Key="GalleryGridItemsPanel">
            <UniformGrid Columns="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" VerticalAlignment="Top" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="GalleryListItemsPanel">
            <StackPanel />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="GalleryGridTemplate">
            <Border Margin="8" Background="#111D2F" CornerRadius="15" BorderBrush="#26364D" BorderThickness="1" ClipToBounds="True">
                <StackPanel>
                    <Border Height="150" Background="#050B14" BorderBrush="#18283D" BorderThickness="0,0,0,1" ClipToBounds="True">
                        <Grid>
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True" />
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#DD111D2F" CornerRadius="8" Margin="8" Padding="7,4" ToolTip="잡고 드래그: 사이드바 폴더로 이동 / 탐색기로 복사" Cursor="Hand" Tag="DragHandle" PreviewMouseLeftButtonDown="ReorderHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="ReorderHandle_PreviewMouseMove"><TextBlock Text="⠿" Foreground="#BFDBFE" FontSize="14" /></Border>
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#CC0B1220" CornerRadius="7" Margin="42,8,8,8" Padding="7,3">
                                <TextBlock Text="{Binding Badge}" FontSize="11" FontWeight="Bold" Foreground="#E5E7EB" />
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#CC7C2D12" BorderBrush="#F97316" BorderThickness="1" CornerRadius="7" Margin="8" Padding="7,3" ToolTip="{Binding SecurityWarningText}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SecurityBadgeText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding SecurityBadgeText}" FontSize="10" FontWeight="Bold" Foreground="#FED7AA" />
                            </Border>
                            <TextBlock Text="{Binding FavoriteMark}" FontSize="18" Foreground="#FBBF24" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,7,10,0" />
                        </Grid>
                    </Border>
                    <StackPanel Margin="12,10,12,12">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DetailText}" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,5,0,0" />
                        <TextBlock Text="{Binding LocationText}" Foreground="#7DD3FC" FontSize="11" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding LocationText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LocationText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding CreatedText}" Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GalleryListTemplate">
            <Border Margin="0,0,0,8" Padding="10" Background="#111D2F" CornerRadius="14" BorderBrush="#26364D" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="42" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⠿" Foreground="#94A3B8" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="잡고 드래그: 사이드바 폴더로 이동 / 탐색기로 복사" Cursor="Hand" Tag="DragHandle" PreviewMouseLeftButtonDown="ReorderHandle_PreviewMouseLeftButtonDown" PreviewMouseMove="ReorderHandle_PreviewMouseMove" />
                    <Border Grid.Column="1" Width="64" Height="50" Background="#050B14" CornerRadius="10" ClipToBounds="True" HorizontalAlignment="Left">
                        <Grid>
                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#CC0B1220" CornerRadius="6" Margin="4" Padding="5,1">
                                <TextBlock Text="{Binding Badge}" FontSize="9" FontWeight="Bold" Foreground="#E5E7EB" />
                            </Border>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#CC7C2D12" BorderBrush="#F97316" BorderThickness="1" CornerRadius="6" Margin="4" Padding="4,1" ToolTip="{Binding SecurityWarningText}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SecurityBadgeText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="주의" FontSize="8" FontWeight="Bold" Foreground="#FED7AA" />
                            </Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,18,0">
                        <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" FontSize="14.5" />
                        <TextBlock Text="{Binding DetailText}" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding SecurityWarningText}" Foreground="#FDBA74" FontSize="11" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding SecurityWarningText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SecurityBadgeText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding LocationText}" Foreground="#7DD3FC" FontSize="11" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding LocationText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LocationText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="3" Text="{Binding KindText}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="{Binding CreatedText}" Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="5" Text="{Binding FavoriteMark}" Foreground="#FBBF24" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}" TextElement.Foreground="{StaticResource Text}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0A1322" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderSidebarColumn" Width="336" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <StackPanel x:Name="HeaderBrandExpanded" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/logo_shield.png" Width="46" Height="46" Margin="0,0,14,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Private Gallery Vault" FontSize="21" FontWeight="Bold" Foreground="{StaticResource Text}" />
                            <TextBlock Text="안전하게 암호화된 개인 이미지 · 영상 갤러리" Foreground="{StaticResource SubText}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <Grid x:Name="HeaderBrandCollapsed" Visibility="Collapsed" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Assets/Images/logo_shield.png" Width="46" Height="46" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" />
                    </Grid>
                </Grid>

                <Grid Grid.Column="1" Width="430" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#111B2B" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="11" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⌕" FontSize="22" Foreground="{StaticResource SubText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" BorderThickness="0" Height="38" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" ToolTip="주제, 파일명, 확장자 검색" />
                    </Grid>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="＋ 파일 추가" Click="Import_Click" Margin="0,0,8,0" />
                    <Button Content="▣ 주제 추가" Style="{StaticResource GhostButton}" Click="AddTopic_Click" Margin="0,0,8,0" />
                    <Button Content="⚙ 설정" Style="{StaticResource GhostButton}" Click="Settings_Click" Margin="0,0,8,0" />
                    <Button Content="🔒 잠금" Style="{StaticResource GhostButton}" Click="Lock_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="336" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,1,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#081322" Offset="0" />
                        <GradientStop Color="#06101D" Offset="0.55" />
                        <GradientStop Color="#050B16" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid x:Name="SidebarExpandedContent" Margin="16,14,16,14" MinHeight="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="0" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="2,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="보관함" Foreground="{StaticResource Text}" FontSize="15" FontWeight="Bold" />
                                <TextBlock Text="이미지 · 영상 · 문서 · 압축파일" Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,3,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="☰" Width="38" Height="34" Style="{StaticResource GhostButton}" Click="ToggleSidebar_Click" Padding="0" ToolTip="메뉴 접기" />
                        </Grid>

                        <ScrollViewer x:Name="SidebarMainScrollViewer"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False"
                                      VerticalAlignment="Stretch"
                                      Padding="0,0,4,0"
                                      Margin="0,0,-4,0">
                            <StackPanel>
                                <Border Background="#0B1728" BorderBrush="#1E314A" BorderThickness="1" CornerRadius="18" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="4,0,4,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="ManagementCenterToggleButton" Grid.Column="0" Content="▶" FontFamily="Segoe UI Symbol" FontSize="10" Width="24" Height="24" Style="{StaticResource GhostButton}" Click="ToggleManagementCenterSection_Click" Padding="0" Margin="0,0,6,0" ToolTip="관리 센터 펼치기/접기" />
                                    <TextBlock Grid.Column="1" Text="관리 센터" Foreground="{StaticResource Accent2}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="NEW" Foreground="#93C5FD" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                                </Grid>
                                <UniformGrid x:Name="ManagementCenterPanel" Columns="2" Margin="0,0,0,14">
                                    <Button x:Name="ActivityCenterButton" Content="◷ 최근 기록" Style="{StaticResource SidebarButton}" Click="ActivityCenter_Click" Height="34" Margin="0,0,5,6" />
                                    <Button x:Name="DuplicateCenterButton" Content="≋ 중복 관리" Style="{StaticResource SidebarButton}" Click="DuplicateCenter_Click" Height="34" Margin="5,0,0,6" />
                                    <Button x:Name="BackupCenterButton" Content="☁ 백업/복원" Style="{StaticResource SidebarButton}" Click="BackupCenter_Click" Height="34" Margin="0,0,5,0" />
                                    <Button x:Name="TagCenterButton" Content="● 태그/라벨" Style="{StaticResource SidebarButton}" Click="TagCenter_Click" Height="34" Margin="5,0,0,0" />
                                </UniformGrid>
                                <Border Height="1" Background="#203149" Margin="0,0,0,12" />
                                <Grid Margin="4,0,4,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="MediaFilterToggleButton" Grid.Column="0" Content="▶" FontFamily="Segoe UI Symbol" FontSize="10" Width="24" Height="24" Style="{StaticResource GhostButton}" Click="ToggleMediaFilterSection_Click" Padding="0" Margin="0,0,6,0" ToolTip="미디어 필터 펼치기/접기" />
                                    <TextBlock Grid.Column="1" Text="미디어 필터" Foreground="{StaticResource Accent2}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="정렬됨" Foreground="{StaticResource MutedText}" FontSize="11" VerticalAlignment="Center" />
                                </Grid>

                                <StackPanel x:Name="MediaFilterPanel" Margin="0,0,0,4">
                                    <Button x:Name="AllButton" Style="{StaticResource SidebarButton}" Click="All_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▣" Foreground="{StaticResource Accent2}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="전체 항목" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="AllCountText" Text="0"/></Border></Grid>
                                    </Button>
                                    <Button x:Name="ImagesButton" Style="{StaticResource SidebarButton}" Click="Images_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▧" Foreground="#93C5FD" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="이미지" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="ImagesCountText" Text="0"/></Border></Grid>
                                    </Button>
                                    <Button x:Name="VideosButton" Style="{StaticResource SidebarButton}" Click="Videos_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▶" Foreground="#A78BFA" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="동영상" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="VideosCountText" Text="0"/></Border></Grid>
                                    </Button>
                                    <Button x:Name="DocumentsButton" Style="{StaticResource SidebarButton}" Click="Documents_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▤" Foreground="#60A5FA" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="문서" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="DocumentsCountText" Text="0"/></Border></Grid>
                                    </Button>
                                    <Button x:Name="ArchivesButton" Style="{StaticResource SidebarButton}" Click="Archives_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▥" Foreground="#FBBF24" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="압축파일" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="ArchivesCountText" Text="0"/></Border></Grid>
                                    </Button>
                                    <Button x:Name="OtherFilesButton" Style="{StaticResource SidebarButton}" Click="OtherFiles_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="◇" Foreground="#A78BFA" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="기타 파일" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="OtherFilesCountText" Text="0"/></Border></Grid>
                                    </Button>
                                    <Button x:Name="FavoritesButton" Style="{StaticResource SidebarButton}" Click="Favorites_Click" Height="34" Margin="0,0,0,5">
                                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="★" Foreground="#FBBF24" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="즐겨찾기" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><Border Grid.Column="2" Style="{StaticResource CountBadge}"><TextBlock x:Name="FavoritesCountText" Text="0"/></Border></Grid>
                                    </Button>
                                </StackPanel>

                                <Button x:Name="ManageTopicsButton" Style="{StaticResource SidebarButton}" Click="ManageTopics_Click" Height="34">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="▦" Foreground="{StaticResource Accent2}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="주제 폴더 보기" Foreground="{StaticResource Text}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="›" Foreground="{StaticResource SubText}" FontSize="18" VerticalAlignment="Center"/></Grid>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SidebarSectionSeparator" Height="1" Background="#203149" Margin="0,0,0,12" />

                        <Border Background="#0B1728" BorderBrush="#1E314A" BorderThickness="1" CornerRadius="18" Padding="12" Margin="0,0,0,14">
                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Margin="4,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Button x:Name="TopicFolderToggleButton" Grid.Column="0" Content="▶" FontFamily="Segoe UI Symbol" FontSize="10" Width="24" Height="24" Style="{StaticResource GhostButton}" Click="ToggleTopicFolderSection_Click" Padding="0" Margin="0,2,6,0" ToolTip="주제 폴더 펼치기/접기" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="주제 폴더" Foreground="{StaticResource Accent2}" FontSize="12" FontWeight="Bold" />
                                    <TextBlock Text="여러 주제를 한눈에 보고 바로 전환" Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,2,0,0" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="＋" Width="36" Height="34" Style="{StaticResource GhostButton}" Click="AddTopic_Click" Padding="0" />
                            </Grid>

                            <StackPanel x:Name="TopicFolderPanel" Grid.Row="1">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#081423" BorderBrush="#1E314A" BorderThickness="1" CornerRadius="14" Padding="9,6,8,6" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="⌕" Foreground="{StaticResource Accent2}" FontSize="15" Width="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Grid Grid.Column="1">
                                                <TextBox x:Name="TopicFolderSearchBox"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Height="34"
                                                         Padding="0,4,0,0"
                                                         VerticalContentAlignment="Center"
                                                         FontSize="13.5"
                                                         Foreground="{StaticResource Text}"
                                                         CaretBrush="{StaticResource Accent2}"
                                                         TextChanged="TopicFolderSearchBox_TextChanged"
                                                         ToolTip="주제 폴더 이름 또는 설명 검색" />
                                                <TextBlock x:Name="TopicFolderSearchPlaceholder"
                                                           Text="주제 폴더 검색"
                                                           Foreground="{StaticResource MutedText}"
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False"
                                                           Margin="2,1,0,0" />
                                            </Grid>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock x:Name="TopicFolderSearchCountText" Text="" Foreground="{StaticResource MutedText}" FontSize="11" VerticalAlignment="Center" Margin="0,0,7,0" />
                                                <Button x:Name="TopicFolderSearchClearButton" Content="×" Width="24" Height="24" Style="{StaticResource GhostButton}" Padding="0" Click="ClearTopicFolderSearch_Click" Visibility="Collapsed" ToolTip="검색어 지우기" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Button x:Name="TopicFolderSortButton"
                                            Grid.Column="1"
                                            Content="⇅"
                                            Width="38"
                                            Height="38"
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Style="{StaticResource GhostButton}"
                                            Padding="0"
                                            Click="TopicFolderSortButton_Click"
                                            ToolTip="주제 폴더 정렬" />

                                    <Popup x:Name="TopicFolderSortPopup"
                                           PlacementTarget="{Binding ElementName=TopicFolderSortButton}"
                                           Placement="Bottom"
                                           HorizontalOffset="-176"
                                           VerticalOffset="7"
                                           AllowsTransparency="True"
                                           StaysOpen="False"
                                           PopupAnimation="Fade">
                                        <Border Width="220"
                                                Background="#0B1728"
