<Window x:Class="PrivateGalleryVault.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="비밀번호 변경" Width="620" Height="520" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid Background="{StaticResource AppBackground}" Margin="28">
        <Border Style="{StaticResource Card}" Padding="28" Effect="{StaticResource SoftShadow}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                    <Image Source="/Assets/Images/illustration_security.png" Width="62" Height="62" Margin="0,0,16,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="비밀번호 변경" FontSize="26" FontWeight="Bold" />
                        <TextBlock Text="현재 비밀번호로 Vault를 확인한 뒤 새 비밀번호로 교체합니다." Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="현재 비밀번호" FontWeight="SemiBold" Margin="0,0,0,8" />
                <PasswordBox x:Name="CurrentBox" Height="42" />

                <TextBlock Text="새 비밀번호" FontWeight="SemiBold" Margin="0,18,0,8" />
                <PasswordBox x:Name="NewBox" Height="42" PasswordChanged="PasswordChanged" />

                <TextBlock Text="새 비밀번호 확인" FontWeight="SemiBold" Margin="0,18,0,8" />
                <PasswordBox x:Name="ConfirmBox" Height="42" PasswordChanged="PasswordChanged" />

                <Grid Margin="0,20,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="비밀번호 강도" FontWeight="SemiBold" />
                    <TextBlock x:Name="StrengthText" Grid.Column="1" Text="0 / 4" Foreground="{StaticResource SubText}" />
                </Grid>
                <ProgressBar x:Name="StrengthBar" Minimum="0" Maximum="4" Height="7" />

                <TextBlock x:Name="MessageText" Foreground="{StaticResource Danger}" TextWrapping="Wrap" MinHeight="28" Margin="0,16,0,0" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="취소" Style="{StaticResource GhostButton}" Click="Cancel_Click" Margin="0,0,10,0" />
                    <Button Grid.Column="1" Content="비밀번호 변경 저장" Click="Save_Click" Margin="10,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
