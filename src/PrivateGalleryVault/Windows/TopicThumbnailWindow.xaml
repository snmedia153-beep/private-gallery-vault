<Window x:Class="PrivateGalleryVault.Windows.TopicThumbnailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="주제 썸네일 지정" Width="980" Height="720" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#F8FAFC">
    <Grid Background="#7A030712">
        <Border Margin="28"
                Background="#071221"
                BorderBrush="#26364D"
                BorderThickness="1.2"
                CornerRadius="28"
                Padding="24"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.38" Color="#000000" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="58" Height="58" CornerRadius="16" Background="#0B1730" BorderBrush="#24446C" BorderThickness="1" Margin="0,0,14,0">
                            <Image Source="/Assets/Images/topic_default_folder.png" Stretch="Uniform" Margin="7" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TitleText" Text="주제 썸네일 지정" FontSize="25" FontWeight="Bold" Foreground="{StaticResource Text}" />
                            <TextBlock Text="기존 미디어 썸네일을 선택하거나 기본 폴더 이미지로 되돌립니다."
                                       Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Width="38" Height="38" CornerRadius="12" Background="#0D1B31" BorderBrush="#243850" BorderThickness="1">
                        <Button Content="✕" IsCancel="True" Background="Transparent" BorderThickness="0" Foreground="#D6E4FF" FontWeight="SemiBold" Cursor="Hand" />
                    </Border>
                </Grid>

                <Border Grid.Row="1" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="최근 미디어" Foreground="{StaticResource Text}" FontWeight="SemiBold" FontSize="15" />
                            <TextBlock Text="이 주제에 포함된 미디어 중 하나를 대표 썸네일로 지정할 수 있습니다."
                                       Foreground="{StaticResource SubText}" Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="기본 폴더 이미지로 설정" Style="{StaticResource GhostButton}" Click="UseDefault_Click" Height="40" MinWidth="168" Margin="14,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#06111F" BorderBrush="#223652" BorderThickness="1" CornerRadius="22" Padding="16" SnapsToDevicePixels="True">
                    <Grid>
                        <StackPanel x:Name="EmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                            <Image Source="/Assets/Images/empty_media.png" Width="210" Height="160" Stretch="Uniform" />
                            <TextBlock Text="이 주제에 선택 가능한 미디어가 없습니다." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource Text}" />
                            <TextBlock Text="먼저 이미지나 영상을 추가해 주세요." Foreground="{StaticResource SubText}" HorizontalAlignment="Center" Margin="0,7,0,0" />
                        </StackPanel>

                        <ListBox x:Name="MediaList"
                                 SelectionMode="Single"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Padding="2">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="180" Margin="7" Background="#111D2F" CornerRadius="16" BorderBrush="#2A3C56" BorderThickness="1" ClipToBounds="True">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.16" Color="#000000" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <Border Height="120" Background="#050B14" BorderBrush="#18283D" BorderThickness="0,0,0,1" ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#CC0B1220" CornerRadius="7" Margin="8" Padding="6,2">
                                                        <TextBlock Text="{Binding Badge}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Text}" />
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold" Margin="10,9,10,10" Foreground="{StaticResource Text}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border x:Name="LoadingOverlay"
                                Visibility="Collapsed"
                                Background="#D906111F"
                                CornerRadius="20"
                                Padding="24"
                                Panel.ZIndex="10">
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Width="360"
                                    Background="#0B1730"
                                    BorderBrush="#2F7CFF"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="24">
                                <StackPanel>
                                    <TextBlock Text="썸네일을 불러오는 중입니다"
                                               Foreground="{StaticResource Text}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center" />
                                    <TextBlock x:Name="LoadingText"
                                               Text="미디어 목록을 준비하고 있습니다..."
                                               Foreground="{StaticResource SubText}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,16" />
                                    <ProgressBar x:Name="LoadProgressBar"
                                                 Height="9"
                                                 Minimum="0"
                                                 Maximum="1"
                                                 IsIndeterminate="True" />
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="#081726" BorderBrush="#1E3047" BorderThickness="1" CornerRadius="18" Padding="16" Margin="0,18,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="취소" Style="{StaticResource GhostButton}" Click="Cancel_Click" Width="120" Height="42" Margin="0,0,10,0" />
                        <Button Content="적용" Click="Apply_Click" Width="140" Height="42" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
