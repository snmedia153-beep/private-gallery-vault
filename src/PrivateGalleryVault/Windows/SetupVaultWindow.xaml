<Window x:Class="PrivateGalleryVault.Windows.SetupVaultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="새 Vault 생성" Width="1180" Height="720" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#0A1322" BorderBrush="{StaticResource Stroke}" BorderThickness="0,0,0,1">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Source="/Assets/Images/logo_shield.png" Width="42" Height="42" Margin="0,0,14,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Private Gallery Vault" FontSize="21" FontWeight="Bold" />
                    <TextBlock Text="안전하게 암호화된 개인 이미지 · 영상 갤러리" Foreground="{StaticResource SubText}" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="64,38,64,34">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="112" />
            </Grid.RowDefinitions>

            <Grid Grid.Column="0" Margin="0,0,42,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="새 Vault 생성" FontSize="44" FontWeight="Bold" />
                    <TextBlock Text="이 앱에는 계정이나 아이디가 없습니다." FontSize="17" Foreground="{StaticResource SubText}" Margin="0,18,0,0" />
                    <TextBlock Text="Vault를 보호할 마스터 비밀번호를 생성하세요." FontSize="17" Foreground="{StaticResource Text}" Margin="0,7,0,0" />
                </StackPanel>
                <Image Grid.Row="1" Source="/Assets/Images/illustration_vault_create.png" Stretch="Uniform" Margin="8,10,8,0" />
                <Border Grid.Row="2" Background="#121B2B" BorderBrush="#304159" BorderThickness="1" CornerRadius="14" Padding="18" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" FontSize="24" Foreground="#FBBF24" VerticalAlignment="Top" Margin="0,0,14,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="마스터 비밀번호를 잊어버리면 Vault를 복구할 수 없습니다." FontWeight="SemiBold" Foreground="#FDE68A" />
                            <TextBlock Text="반드시 안전한 곳에 기억하거나 기록해 두세요." Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="24" Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Width="44" Height="44" CornerRadius="22" Background="#15233A" BorderBrush="#29405E" BorderThickness="1" Margin="0,0,14,0">
                            <TextBlock Text="🔒" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="마스터 비밀번호 설정" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="강력한 비밀번호는 Vault의 모든 데이터를 안전하게 보호합니다." Foreground="{StaticResource SubText}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="새 비밀번호" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid>
                                <PasswordBox x:Name="PasswordBox" Height="42" PasswordChanged="PasswordBox_PasswordChanged" />
                                <TextBox x:Name="PasswordTextBox" Height="42" Visibility="Collapsed" TextChanged="VisiblePassword_TextChanged" />
                            </Grid>

                            <TextBlock Text="비밀번호 확인" FontWeight="SemiBold" Margin="0,14,0,8" />
                            <Grid>
                                <PasswordBox x:Name="ConfirmBox" Height="42" PasswordChanged="PasswordBox_PasswordChanged" />
                                <TextBox x:Name="ConfirmTextBox" Height="42" Visibility="Collapsed" TextChanged="VisiblePassword_TextChanged" />
                            </Grid>

                            <TextBlock Text="힌트 (선택)" FontWeight="SemiBold" Margin="0,14,0,8" />
                            <TextBox x:Name="HintBox" Height="42" ToolTip="비밀번호를 직접 저장하지 않는 힌트입니다." />

                            <Grid Margin="0,16,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="비밀번호 강도" FontWeight="SemiBold" />
                                <TextBlock x:Name="StrengthText" Grid.Column="1" Text="0 / 4" Foreground="{StaticResource SubText}" />
                            </Grid>
                            <ProgressBar x:Name="StrengthBar" Height="7" Minimum="0" Maximum="4" Value="0" />
                            <TextBlock x:Name="StrengthHintText" Text="영문, 숫자, 특수문자를 조합해 8자 이상으로 설정하세요." Foreground="{StaticResource SubText}" Margin="0,8,0,0" TextWrapping="Wrap" />

                            <CheckBox x:Name="ShowPasswordCheck" Content="비밀번호 표시" Margin="0,14,0,0" Checked="ShowPasswordCheck_Changed" Unchecked="ShowPasswordCheck_Changed" />

                            <TextBlock x:Name="MessageText" Foreground="{StaticResource Danger}" TextWrapping="Wrap" Margin="0,12,0,0" MinHeight="24" />
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <Border Height="1" Background="{StaticResource Stroke}" Margin="0,0,0,16" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="취소" Style="{StaticResource GhostButton}" Click="Cancel_Click" Margin="0,0,10,0" Height="44" />
                            <Button Grid.Column="1" Content="🛡  Vault 만들기" Click="Create_Click" Margin="10,0,0,0" Height="44" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/logo_shield.png" Width="48" Height="48" Margin="0,0,14,0" />
                        <StackPanel>
                            <TextBlock Text="AES-256 암호화 저장" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="모든 파일과 메타데이터를 안전하게 보호합니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="18" Margin="12,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/topic_default_folder.png" Width="48" Height="48" Margin="0,0,14,0" />
                        <StackPanel>
                            <TextBlock Text="휴대 가능한 Vault" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="폴더 전체를 다른 PC로 옮겨도 그대로 사용할 수 있습니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Assets/Images/illustration_security.png" Width="48" Height="48" Margin="0,0,14,0" />
                        <StackPanel>
                            <TextBlock Text="로컬 전용 · 완전한 프라이버시" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="데이터는 내 PC에만 저장되며 외부로 전송되지 않습니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
