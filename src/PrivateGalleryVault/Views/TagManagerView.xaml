<UserControl x:Class="PrivateGalleryVault.Views.TagManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" TextElement.Foreground="{StaticResource Text}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="240" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource Card}" Background="#0B1626" Padding="16" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="태그 관리" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="색상 라벨로 파일을 빠르게 분류합니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" Margin="0,5,0,14" />
                </StackPanel>
                <ListBox x:Name="TagList" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="TagList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,7" Padding="10" Background="#101B2C" BorderBrush="#203149" BorderThickness="1" CornerRadius="13">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Ellipse Width="14" Height="14" Fill="{Binding Brush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="2" Content="＋ 새 태그" Style="{StaticResource GhostButton}" Click="AddTag_Click" Margin="0,12,0,0" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource Card}" Background="#0B1626" Padding="18" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="파일 / 앨범 라벨링" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="파일을 선택하고 오른쪽 색상 팔레트를 클릭하면 즉시 적용하거나 해제합니다." Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="↻ 새로고침" Style="{StaticResource GhostButton}" Click="Refresh_Click" />
                </Grid>

                <ListBox x:Name="MediaList" Grid.Row="1" Margin="0,18,0,0" SelectionMode="Extended" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="MediaList_SelectionChanged">
                    <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="190" Margin="0,0,12,12" Background="#101B2C" BorderBrush="#203149" BorderThickness="1" CornerRadius="16" Padding="10">
                                <StackPanel>
                                    <Grid>
                                        <Border Height="104" Background="#050B14" CornerRadius="12" ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Background="#1D4ED8" CornerRadius="8" Padding="7,2" Margin="6">
                                            <TextBlock Text="{Binding Badge}" FontSize="10" FontWeight="Bold" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,9,0,0" />
                                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,3,0,0" />
                                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,8,0,0">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Brush}" CornerRadius="8" Padding="7,2" Margin="0,0,5,5">
                                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource Card}" Background="#0D1726" Padding="18">
            <StackPanel>
                <TextBlock Text="색상 팔레트" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="선택한 파일에 색상을 바로 적용하거나 해제합니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" Margin="0,6,0,16" />
                <UniformGrid x:Name="PaletteGrid" Columns="5" />
                <Border Background="#0B1626" BorderBrush="#203149" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,18,0,0">
                    <TextBlock x:Name="PaletteStatusText" Text="파일을 선택한 뒤 색상을 클릭하세요." Foreground="{StaticResource SubText}" TextWrapping="Wrap" LineHeight="20" />
                </Border>
                <TextBlock Text="TIP" Foreground="{StaticResource Accent2}" FontWeight="Bold" Margin="0,22,0,6" />
                <TextBlock Text="색상이 없는 파일에는 클릭 즉시 적용되고, 이미 같은 색상이 있으면 클릭 즉시 제거됩니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" LineHeight="22" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
