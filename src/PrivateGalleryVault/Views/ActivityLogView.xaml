<UserControl x:Class="PrivateGalleryVault.Views.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" TextElement.Foreground="{StaticResource Text}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,14,0" Background="#0B1626">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="최근 작업 기록" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="가져오기, 변경, 내보내기, 중복 처리 작업을 한눈에 확인합니다." Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="↻ 새로고침" Style="{StaticResource GhostButton}" Click="Refresh_Click" />
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,16">
                    <Button Content="전체" Tag="" Click="Filter_Click" Margin="0,0,8,0" />
                    <Button Content="가져오기" Tag="import" Style="{StaticResource GhostButton}" Click="Filter_Click" Margin="0,0,8,0" />
                    <Button Content="변경" Tag="topic" Style="{StaticResource GhostButton}" Click="Filter_Click" Margin="0,0,8,0" />
                    <Button Content="내보내기" Tag="export" Style="{StaticResource GhostButton}" Click="Filter_Click" Margin="0,0,8,0" />
                    <Button Content="중복" Tag="duplicate" Style="{StaticResource GhostButton}" Click="Filter_Click" />
                </StackPanel>

                <ListBox x:Name="ActivityList" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,9">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Rectangle Width="2" Fill="#26364D" HorizontalAlignment="Center" />
                                    <Border Width="28" Height="28" CornerRadius="10" Background="{Binding AccentBrush}" BorderBrush="#385A87" BorderThickness="1" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" />
                                    </Border>
                                </Grid>
                                <Border Grid.Column="1" Background="#0F1B2D" BorderBrush="#203149" BorderThickness="1" CornerRadius="14" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Actor}" Foreground="{StaticResource MutedText}" FontSize="11" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding TimeText}" Foreground="{StaticResource MutedText}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <StackPanel Grid.Column="1">
            <Border Style="{StaticResource Card}" Padding="18" Background="#0D1726" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="요약 정보" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="오늘" Foreground="{StaticResource SubText}" Margin="0,14,0,6" />
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="작업 수"/><TextBlock x:Name="TodayCountText" Grid.Column="1" Text="0" Foreground="{StaticResource Accent2}" FontWeight="Bold"/></Grid>
                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="성공"/><TextBlock x:Name="SuccessCountText" Grid.Column="1" Text="0" Foreground="{StaticResource Success}" FontWeight="Bold"/></Grid>
                    <Grid Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="실패"/><TextBlock x:Name="FailCountText" Grid.Column="1" Text="0" Foreground="{StaticResource Danger}" FontWeight="Bold"/></Grid>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Padding="18" Background="#0D1726">
                <StackPanel>
                    <TextBlock Text="작업 비율" FontSize="18" FontWeight="Bold" />
                    <ItemsControl x:Name="SummaryList" Margin="0,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource SubText}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Count}" Foreground="{StaticResource Text}" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="전체 기록 내보내기" Style="{StaticResource GhostButton}" Margin="0,14,0,0" Click="Export_Click" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
