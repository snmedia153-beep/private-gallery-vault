<UserControl x:Class="PrivateGalleryVault.Views.DuplicateManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" TextElement.Foreground="{StaticResource Text}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource Card}" Padding="14" Background="#0B1626" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="중복 파일 관리" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="source hash 기준으로 같은 파일을 그룹화합니다." Foreground="{StaticResource SubText}" FontSize="12" Margin="0,5,0,14" TextWrapping="Wrap" />
                </StackPanel>
                <ListBox x:Name="GroupList" Grid.Row="1" Background="Transparent" BorderThickness="0" SelectionChanged="GroupList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="10" Background="#101B2C" BorderBrush="#203149" BorderThickness="1" CornerRadius="14">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1D4ED8" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Count}" FontSize="11" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="2" Content="↻ 중복 새로 검색" Style="{StaticResource GhostButton}" Click="Refresh_Click" Margin="0,12,0,0" />
            </Grid>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="18" Background="#0B1626" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="GroupTitleText" Text="중복 그룹을 선택하세요" FontSize="24" FontWeight="Bold" />
                        <TextBlock x:Name="GroupHashText" Text="같은 내용의 파일을 원본/중복으로 비교합니다." Foreground="{StaticResource SubText}" Margin="0,5,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#052E1A" BorderBrush="#16A34A" BorderThickness="1" CornerRadius="12" Padding="10,5" VerticalAlignment="Center">
                        <TextBlock Text="해시 일치" Foreground="#86EFAC" FontWeight="SemiBold" />
                    </Border>
                </Grid>
                <ItemsControl x:Name="PreviewList" Grid.Row="1" Margin="0,18,0,0">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="210" Margin="0,0,12,12" Background="#101B2C" BorderBrush="#203149" BorderThickness="1" CornerRadius="16" Padding="10">
                                <StackPanel>
                                    <Border Height="120" Background="#050B14" CornerRadius="12" ClipToBounds="True">
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                    </Border>
                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Text="{Binding Role}" Foreground="{Binding RoleBrush}" FontWeight="Bold" FontSize="12" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding Detail}" Foreground="{StaticResource SubText}" FontSize="12" Margin="0,3,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="원본 유지" Margin="0,0,8,0" />
                    <Button Content="다른 폴더로 이동" Style="{StaticResource GhostButton}" Margin="0,0,8,0" />
                    <Button Content="중복 파일 삭제" Style="{StaticResource DangerButton}" Click="DeleteDuplicates_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18" Background="#0D1726">
            <StackPanel>
                <TextBlock Text="비교 정보" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="파일 이름" Foreground="{StaticResource SubText}" Margin="0,18,0,4" />
                <TextBlock x:Name="CompareFileNameText" Text="-" TextWrapping="Wrap" />
                <TextBlock Text="절약 가능 공간" Foreground="{StaticResource SubText}" Margin="0,18,0,4" />
                <TextBlock x:Name="WastedSizeText" Text="0 B" Foreground="{StaticResource Accent2}" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="일치 항목" Foreground="{StaticResource SubText}" Margin="0,18,0,8" />
                <TextBlock Text="✓ 파일 내용&#x0a;✓ 원본 해시&#x0a;✓ 크기 기준 비교" Foreground="{StaticResource Success}" LineHeight="24" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
