<UserControl x:Class="PrivateGalleryVault.Views.BackupRestoreWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" TextElement.Foreground="{StaticResource Text}">
        <Border Style="{StaticResource Card}" Background="#0B1626" Padding="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="백업 / 복원 마법사" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="vault 폴더 전체를 안전하게 백업하고 복원 준비를 도와줍니다." Foreground="{StaticResource SubText}" Margin="0,6,0,0" />
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="5" Margin="0,24,20,22">
                    <Border Background="#1D4ED8" CornerRadius="16" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="1" FontWeight="Bold"/><TextBlock Text="백업 대상" FontSize="12"/></StackPanel></Border>
                    <Border Background="#13233A" BorderBrush="#26364D" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="2" Foreground="{StaticResource Accent2}"/><TextBlock Text="암호 확인" FontSize="12" Foreground="{StaticResource SubText}"/></StackPanel></Border>
                    <Border Background="#13233A" BorderBrush="#26364D" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="3" Foreground="{StaticResource Accent2}"/><TextBlock Text="옵션 선택" FontSize="12" Foreground="{StaticResource SubText}"/></StackPanel></Border>
                    <Border Background="#13233A" BorderBrush="#26364D" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,0,8,0"><StackPanel><TextBlock Text="4" Foreground="{StaticResource Accent2}"/><TextBlock Text="요약" FontSize="12" Foreground="{StaticResource SubText}"/></StackPanel></Border>
                    <Border Background="#13233A" BorderBrush="#26364D" BorderThickness="1" CornerRadius="16" Padding="12"><StackPanel><TextBlock Text="5" Foreground="{StaticResource Accent2}"/><TextBlock Text="완료" FontSize="12" Foreground="{StaticResource SubText}"/></StackPanel></Border>
                </UniformGrid>

                <StackPanel Grid.Row="2" Margin="0,0,22,0">
                    <Border Background="#0F1B2D" BorderBrush="#203149" BorderThickness="1" CornerRadius="18" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="안전한 백업" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="현재 vault 전체를 .pgvbackup 패키지로 압축합니다. 기존 파일은 이미 AES 암호화되어 보관됩니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" Margin="0,6,0,16" />
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock x:Name="BackupPathText" Text="백업 위치를 선택하세요" Foreground="{StaticResource SubText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/><Button Grid.Column="1" Content="위치 선택" Style="{StaticResource GhostButton}" Click="ChooseBackupPath_Click" Margin="12,0,0,0"/></Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="#101B2C" BorderBrush="#315B89" BorderThickness="1" CornerRadius="18" Padding="18">
                        <StackPanel>
                            <TextBlock Text="주의사항" Foreground="#FBBF24" FontWeight="Bold" />
                            <TextBlock Text="복원은 현재 보관함을 교체하는 민감한 작업입니다. 복원 전 현재 Vault를 자동으로 안전 백업하고, 복원 완료 후 앱을 다시 시작합니다." Foreground="{StaticResource SubText}" TextWrapping="Wrap" LineHeight="22" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Grid.RowSpan="4" Style="{StaticResource Card}" Background="#0D1726" Padding="18">
                    <StackPanel>
                        <TextBlock Text="진행 상태" FontSize="18" FontWeight="Bold" />
                        <Grid Width="150" Height="150" HorizontalAlignment="Center" Margin="0,22,0,12">
                            <Ellipse Stroke="#1E3A8A" StrokeThickness="12" />
                            <Ellipse Stroke="#60A5FA" StrokeThickness="12" StrokeDashArray="8 6" />
                            <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                        <ProgressBar x:Name="BackupProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" />
                        <TextBlock x:Name="BackupStatusText" Text="대기 중" Foreground="{StaticResource SubText}" Margin="0,12,0,0" TextWrapping="Wrap" />
                        <TextBlock Text="백업 대상" FontWeight="SemiBold" Margin="0,24,0,6" />
                        <TextBlock x:Name="VaultPathText" Foreground="{StaticResource SubText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,22,0">
                    <Button Content="복원 파일 선택/복원" Style="{StaticResource GhostButton}" Click="InspectRestore_Click" Margin="0,0,8,0" />
                    <Button Content="백업 시작" Click="StartBackup_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
